pipeline {
    agent any

    environment {
        CARGO_HOME = "${WORKSPACE}/.cargo"
        RUSTUP_HOME = "${WORKSPACE}/.rustup"
        PATH = "${WORKSPACE}/.cargo/bin:${PATH}"
    }
    
    triggers {
        pollSCM('H/5 * * * *')
    }
    
    stages {
        stage('Setup Rust Toolchain') {
            steps {
                script {
                    sh '''
                        if [ ! -d ${WORKSPACE}/.cargo ]; then
                            curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path
                            export PATH="${WORKSPACE}/.cargo/bin:$PATH"
                            rustup component add rustfmt clippy
                        fi
                        
                        # Ensure we have the latest stable toolchain
                        rustc --version
                        cargo --version
                    '''
                }
            }
        }

        stage('Cargo Check') {
            steps {
                sh 'cargo check --all-targets --all-features'
            }
        }

        stage('Cargo Format') {
            steps {
                sh 'cargo fmt -- --check'
            }
        }

        stage('Cargo Test') {
            steps {
                sh 'cargo test --all-features --verbose'
            }
        }

        stage('Cargo Clippy') {
            steps {
                sh '''
                    cargo clippy --all-features --all-targets -- -D warnings -D clippy::pedantic
                '''
            }
        }
        
        stage('Security Audit') {
            steps {
                sh '''
                    # Install cargo-audit if not present
                    if ! command -v cargo-audit &> /dev/null; then
                        cargo install cargo-audit
                    fi
                    cargo audit
                '''
            }
        }

        stage('Build Release') {
            steps {
                sh 'cargo build --release'
            }
        }

        stage('Run Verification Test') {
            steps {
                sh '''
                    echo "Running base64 verification test..."
                    ./target/release/base64check --runs 100000 --threads 2 --report-interval 25000
                '''
            }
        }

        stage('Benchmark') {
            steps {
                sh '''
                    # Install cargo-criterion if not present
                    if ! command -v cargo-criterion &> /dev/null; then
                        cargo install cargo-criterion
                    fi
                    cargo bench
                '''
            }
        }
    }

    post {
        always {
            // Archive build artifacts
            archiveArtifacts artifacts: 'target/release/base64check', fingerprint: true, allowEmptyArchive: true
            
            // Clean workspace but preserve cargo cache
            sh '''
                # Clean build artifacts but keep cargo registry cache
                cargo clean
                rm -rf target/debug target/doc
            '''
        }
        
        success {
            emailext(
                to: 'stephen.battista@gmail.com',
                subject: "Jenkins: SUCCESS - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """Build succeeded for base64check!
                
                Changes: ${env.BUILD_URL}changes
                Console: ${env.BUILD_URL}console
                
                All tests passed and verification completed successfully."""
            )
        }
        
        failure {
            emailext(
                to: 'stephen.battista@gmail.com',
                subject: "Jenkins: FAILURE - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """Build failed for base64check.
                
                Please check the console output for details:
                ${env.BUILD_URL}console
                
                Changes that may have caused this failure:
                ${env.BUILD_URL}changes"""
            )
        }
        
        unstable {
            emailext(
                to: 'stephen.battista@gmail.com',
                subject: "Jenkins: UNSTABLE - ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """Build is unstable for base64check.
                
                Some tests may have failed or there were warnings.
                Console: ${env.BUILD_URL}console"""
            )
        }
    }
}
